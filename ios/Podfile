# React Native 0.82+ Podfile
# Load React Native pods helper
react_native_path = File.expand_path('../node_modules/react-native', __dir__)
require_relative File.join(react_native_path, 'scripts', 'react_native_pods.rb')

# Define minimum iOS version (React Native 0.82 requires iOS 15.1+)
def min_ios_version_supported
  '15.1'
end

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'chandrajewellery' do
  # Disable Sentry before autolinking (react-native.config.js should handle this, but ensure it here too)
  ENV['SENTRY_SKIP_AUTO_SETUP'] = '1'

  # Auto-link React Native modules (Sentry should be excluded via react-native.config.js)
  config = use_native_modules!
  config ||= { reactNativePath: '../node_modules/react-native' }
  
  # Force exclude Sentry from autolinking (causes C++ compilation errors)
  if config && config[:ios_packages]
    original_count = config[:ios_packages].length
    config[:ios_packages] = config[:ios_packages].reject do |pkg|
      name = (pkg[:name] || pkg['name'] || '').to_s.downcase
      name.include?('sentry') || name.include?('rnsentry')
    end
    if config[:ios_packages].length < original_count
      puts "🚫 Excluded Sentry from iOS autolinking (#{original_count - config[:ios_packages].length} package(s) removed)"
    end
  end
  
  # Use React Native pods
  # Use relative path from ios directory
  use_react_native!(
    path: '../node_modules/react-native',
    app_path: '..'
  )
  
  # Firebase pods
  pod 'RNFBApp', :path => '../node_modules/@react-native-firebase/app'
  pod 'RNFBMessaging', :path => '../node_modules/@react-native-firebase/messaging'
  pod 'GoogleUtilities', :modular_headers => true
  pod 'Firebase/Core', :modular_headers => true
  pod 'Firebase/Messaging', :modular_headers => true

  post_install do |installer|
    # COMPLETELY REMOVE Sentry from the build (causes C++ compilation errors)
    puts "🚫 Removing Sentry targets and dependencies..."
    
    # Remove Sentry targets from pods project
    installer.pods_project.targets.each do |target|
      if target.name.include?('Sentry') || target.name.include?('RNSentry')
        puts "  Removing target: #{target.name}"
        target.remove_from_project
      end
    end
    
    # Remove Sentry from aggregate targets
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.pod_targets.each do |pod_target|
        if pod_target.name.include?('Sentry') || pod_target.name.include?('RNSentry')
          puts "  Removing pod target: #{pod_target.name}"
          aggregate_target.pod_targets.delete(pod_target)
        end
      end
    end
    
    # Only call react_native_post_install if it's defined
    if defined?(react_native_post_install) && config && config[:reactNativePath]
      react_native_post_install(
        installer,
        config[:reactNativePath],
        :mac_catalyst_enabled => false,
      )
    end
    
    # Fix codegen file dependency issues
    # Disable dependency scanning for targets that use generated files
    # This prevents Xcode from looking for files before codegen generates them
    installer.pods_project.targets.each do |target|
      target_name_lower = target.name.downcase
      if target_name_lower.include?('rnscreens') || 
         target_name_lower.include?('rnsvg') || 
         target_name_lower.include?('rngesturehandler') || 
         target_name_lower.include?('safeareacontext') ||
         target_name_lower.include?('react-native-screens') ||
         target_name_lower.include?('react-native-svg') ||
         target_name_lower.include?('react-native-gesture-handler') ||
         target_name_lower.include?('react-native-safe-area-context')
        target.build_configurations.each do |config|
          # Disable dependency scanning to prevent "file not found" errors for generated files
          config.build_settings['CLANG_DEPENDENCY_SCANNING'] = 'NO'
        end
      end
    end
    
    # Note: react-native-vector-icons fonts are automatically linked via CocoaPods
    # Custom fonts (Avenir) need to be manually added in Xcode (see FONT_SETUP_INSTRUCTIONS.md)
    
    # Fix module import issues
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['LIBRARY_SEARCH_PATHS'] ||= []
        config.build_settings['LIBRARY_SEARCH_PATHS'] << '$(inherited)'
        
        # Fix module import issues
        config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
        config.build_settings['DEFINES_MODULE'] = 'YES'
        config.build_settings['SWIFT_OBJC_INTEROP_MODE'] = 'objc'
        
        # Fix module map file issues for Clang dependency scanner
        config.build_settings['CLANG_MODULES_AUTOLINK'] = 'YES'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        
        # Fix Swift system module imports (Xcode 26 compatibility)
        config.build_settings['SWIFT_INCLUDE_PATHS'] ||= []
        config.build_settings['SWIFT_INCLUDE_PATHS'] << '$(inherited)'
        config.build_settings['SWIFT_FORCE_MODULE_IMPORT'] = 'NO'
        config.build_settings['SWIFT_ACTIVE_COMPILATION_CONDITIONS'] ||= []
        config.build_settings['SWIFT_ACTIVE_COMPILATION_CONDITIONS'] << '$(inherited)'
        
        # Ensure proper SDK path
        if config.build_settings['SDKROOT'].nil?
          config.build_settings['SDKROOT'] = 'iphoneos'
        end
        
        # Fix Firebase pods to find FirebaseCore module
        # Apply to all Firebase targets that depend on FirebaseCore
        target_name_lower = target.name.downcase
        if target_name_lower == 'firebasemessaging' || target_name_lower == 'firebaseinstallations' ||
           (target_name_lower.include?('firebasemessaging') && !target_name_lower.include?('privacy')) ||
           (target_name_lower.include?('firebaseinstallations') && !target_name_lower.include?('privacy'))
          firebase_core_module_flag = '-fmodule-map-file="${PODS_ROOT}/Target Support Files/FirebaseCore/FirebaseCore.modulemap"'
          
          # Add to OTHER_CFLAGS
          other_cflags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
          other_cflags = other_cflags.is_a?(String) ? other_cflags.split(' ') : other_cflags
          unless other_cflags.any? { |f| f.include?('FirebaseCore.modulemap') }
            other_cflags << firebase_core_module_flag
            puts "  Added FirebaseCore module map to #{target.name} OTHER_CFLAGS"
          end
          config.build_settings['OTHER_CFLAGS'] = other_cflags
          
          # Add to OTHER_SWIFT_FLAGS
          other_swift_flags = config.build_settings['OTHER_SWIFT_FLAGS'] || ['$(inherited)']
          other_swift_flags = other_swift_flags.is_a?(String) ? other_swift_flags.split(' ') : other_swift_flags
          unless other_swift_flags.any? { |f| f.include?('FirebaseCore.modulemap') }
            other_swift_flags += ['-Xcc', firebase_core_module_flag]
            puts "  Added FirebaseCore module map to #{target.name} OTHER_SWIFT_FLAGS"
          end
          config.build_settings['OTHER_SWIFT_FLAGS'] = other_swift_flags
        end
        
        # Fix ReactCodegen target to handle generated files properly
        if target.name == 'ReactCodegen'
          # Ensure the generated files directory is properly set
          generated_path = "#{installer.sandbox.root}/../build/generated/ios"
          config.build_settings['PODS_TARGET_SRCROOT'] ||= generated_path
          
          # Disable dependency scanner to avoid issues with generated files
          config.build_settings['CLANG_DEPENDENCY_SCANNING'] = 'NO'
          
          # Ensure proper header search paths - CRITICAL for finding ReactCommon and React-Fabric headers
          header_paths = config.build_settings['HEADER_SEARCH_PATHS'] || []
          header_paths = header_paths.is_a?(String) ? header_paths.split(' ') : header_paths
          
          # Add generated files path
          unless header_paths.any? { |p| p.to_s.include?('build/generated/ios') }
            header_paths << "\"#{generated_path}\""
          end
          
          # Add ReactCommon headers path for TurboModule.h (use variable paths for better compatibility)
          reactcommon_path = "$(PODS_ROOT)/Headers/Public/ReactCommon"
          unless header_paths.any? { |p| p.to_s.include?('Headers/Public/ReactCommon') }
            header_paths << reactcommon_path
          end
          
          # Add React-Fabric headers path for react/renderer/core headers
          reactfabric_path = "$(PODS_ROOT)/Headers/Private/React-Fabric"
          unless header_paths.any? { |p| p.to_s.include?('Headers/Private/React-Fabric') }
            header_paths << reactfabric_path
          end
          
          # Add ReactNativeDependencies path (contains react/nativemodule/core)
          reactnative_deps_path = "$(PODS_ROOT)/ReactNativeDependencies"
          unless header_paths.any? { |p| p.to_s.include?('ReactNativeDependencies') }
            header_paths << reactnative_deps_path
          end
          
          # Also add build directory paths for ReactCommon (when using frameworks)
          reactcommon_build_path = "$(PODS_CONFIGURATION_BUILD_DIR)/ReactCommon"
          unless header_paths.any? { |p| p.to_s.include?('PODS_CONFIGURATION_BUILD_DIR') && p.to_s.include?('ReactCommon') }
            header_paths << reactcommon_build_path
          end
          
          # Ensure inherited is first
          unless header_paths.any? { |p| p.to_s == '$(inherited)' || p.to_s.include?('$(inherited)') }
            header_paths.unshift('$(inherited)')
          end
          
          config.build_settings['HEADER_SEARCH_PATHS'] = header_paths
          
        end
        
        # Fix ReactAppDependencyProvider to include generated headers directory and ReactCodegen
        if target.name == 'ReactAppDependencyProvider'
          config.build_settings['HEADER_SEARCH_PATHS'] ||= []
          generated_header_path = "#{installer.sandbox.root}/../build/generated/ios"
          react_codegen_path = "#{installer.sandbox.root}/Headers/Public/ReactCodegen"
          
          # Convert to array if it's a string
          header_paths = config.build_settings['HEADER_SEARCH_PATHS']
          header_paths = header_paths.is_a?(String) ? header_paths.split(' ') : header_paths
          
          # Add the generated directory if it's not already there
          unless header_paths.any? { |p| p.to_s.include?('build/generated/ios') }
            header_paths << "\"#{generated_header_path}\""
          end
          
          # Add ReactCodegen headers path
          unless header_paths.any? { |p| p.to_s.include?('ReactCodegen') }
            header_paths << "\"#{react_codegen_path}\""
          end
          
          # Ensure inherited is first
          unless header_paths.any? { |p| p.to_s == '$(inherited)' || p.to_s.include?('$(inherited)') }
            header_paths.unshift('$(inherited)')
          end
          
          config.build_settings['HEADER_SEARCH_PATHS'] = header_paths
          
          # Disable dependency scanner for this target to avoid early scanning issues
          config.build_settings['CLANG_DEPENDENCY_SCANNING'] = 'NO'
        end
      end

    end
    
    # Also fix the main project
    installer.pods_project.build_configurations.each do |config|
      config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
      config.build_settings['SWIFT_OBJC_INTEROP_MODE'] = 'objc'
    end
    
    # Ensure FirebaseCore and FirebaseMessaging module maps exist
    firebase_core_modulemap_path = "#{installer.sandbox.root}/Target Support Files/FirebaseCore/FirebaseCore.modulemap"
    firebase_messaging_modulemap_path = "#{installer.sandbox.root}/Target Support Files/FirebaseMessaging/FirebaseMessaging.modulemap"
    
    unless File.exist?(firebase_core_modulemap_path)
      File.write(
        firebase_core_modulemap_path,
        <<~MAP
        module FirebaseCore {
          umbrella header "../../Headers/Public/FirebaseCore/FirebaseCore.h"
          export *
          module * { export * }
        }
        MAP
      )
      puts "Created FirebaseCore.modulemap"
    end

    unless File.exist?(firebase_messaging_modulemap_path)
      File.write(
        firebase_messaging_modulemap_path,
        <<~MAP
        module FirebaseMessaging {
          umbrella header "../../Headers/Public/FirebaseMessaging/FirebaseMessaging.h"
          export *
          module * { export * }
        }
        MAP
      )
      puts "Created FirebaseMessaging.modulemap"
    end
    
    # Fix ReactAppDependencyProvider header search paths and library search paths
    # The generated headers are in build/generated/ios which needs to be in header search paths
    # Also ensure library search paths properly inherit from CocoaPods
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.native_targets.each do |target|
        target.build_configurations.each do |config|
          # Fix header search paths
          existing_header_paths = config.build_settings['HEADER_SEARCH_PATHS'] || []
          # Convert to array if it's a string
          existing_header_paths = existing_header_paths.is_a?(String) ? existing_header_paths.split(' ') : existing_header_paths
          
          # Add the generated codegen directory
          generated_path = "$(SRCROOT)/build/generated/ios"
          unless existing_header_paths.any? { |p| p.to_s.include?('build/generated/ios') }
            existing_header_paths << generated_path
          end
          
          # Add ReactCodegen headers path for the main app target
          react_codegen_path = "$(PODS_ROOT)/Headers/Public/ReactCodegen"
          unless existing_header_paths.any? { |p| p.to_s.include?('ReactCodegen') }
            existing_header_paths << react_codegen_path
          end
          
          # Ensure inherited paths are preserved
          unless existing_header_paths.any? { |p| p.to_s.include?('$(inherited)') }
            existing_header_paths.unshift('$(inherited)')
          end
          config.build_settings['HEADER_SEARCH_PATHS'] = existing_header_paths
          
          # Fix library search paths to ensure DoubleConversion and other pods are found
          # CRITICAL: Must explicitly set LIBRARY_SEARCH_PATHS to inherit from xcconfig
          existing_lib_paths = config.build_settings['LIBRARY_SEARCH_PATHS'] || []
          existing_lib_paths = existing_lib_paths.is_a?(String) ? existing_lib_paths.split(' ') : existing_lib_paths
          
          # Ensure inherited is first so xcconfig paths are included
          unless existing_lib_paths.any? { |p| p.to_s == '$(inherited)' || p.to_s.include?('$(inherited)') }
            existing_lib_paths.unshift('$(inherited)')
          end
          config.build_settings['LIBRARY_SEARCH_PATHS'] = existing_lib_paths
          
          # Ensure OTHER_LDFLAGS also inherits properly
          existing_ldflags = config.build_settings['OTHER_LDFLAGS'] || []
          existing_ldflags = existing_ldflags.is_a?(String) ? existing_ldflags.split(' ') : existing_ldflags
          unless existing_ldflags.any? { |p| p.to_s == '$(inherited)' || p.to_s.include?('$(inherited)') }
            existing_ldflags.unshift('$(inherited)')
          end
          config.build_settings['OTHER_LDFLAGS'] = existing_ldflags
          
          # Disable dependency scanner to avoid issues with generated files during early build phases
          # This prevents the scanner from failing when codegen files don't exist yet
          # Note: This might slow down builds slightly but prevents dependency scanner errors
          if config.build_settings['CLANG_DEPENDENCY_SCANNING'].nil?
            config.build_settings['CLANG_DEPENDENCY_SCANNING'] = 'NO'
          end
          
          # Add Firebase module maps to Swift flags for main app target
          if target.name == 'chandrajewellery'
            firebase_core_flag = '-fmodule-map-file="${PODS_ROOT}/Target Support Files/FirebaseCore/FirebaseCore.modulemap"'
            firebase_messaging_flag = '-fmodule-map-file="${PODS_ROOT}/Target Support Files/FirebaseMessaging/FirebaseMessaging.modulemap"'
            
            # Add to OTHER_SWIFT_FLAGS
            other_swift_flags = config.build_settings['OTHER_SWIFT_FLAGS'] || ['$(inherited)']
            other_swift_flags = other_swift_flags.is_a?(String) ? other_swift_flags.split(' ') : other_swift_flags
            unless other_swift_flags.any? { |f| f.include?('FirebaseCore.modulemap') }
              other_swift_flags += ['-Xcc', firebase_core_flag]
            end
            unless other_swift_flags.any? { |f| f.include?('FirebaseMessaging.modulemap') }
              other_swift_flags += ['-Xcc', firebase_messaging_flag]
            end
            config.build_settings['OTHER_SWIFT_FLAGS'] = other_swift_flags
            
            # Also add to OTHER_CFLAGS for Objective-C compatibility
            other_cflags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
            other_cflags = other_cflags.is_a?(String) ? other_cflags.split(' ') : other_cflags
            unless other_cflags.any? { |f| f.include?('FirebaseCore.modulemap') }
              other_cflags << firebase_core_flag
            end
            unless other_cflags.any? { |f| f.include?('FirebaseMessaging.modulemap') }
              other_cflags << firebase_messaging_flag
            end
            config.build_settings['OTHER_CFLAGS'] = other_cflags
          end
        end
      end
    end
    
    # Fix react-native-video module map path in generated xcconfig files
    # CocoaPods generates paths pointing to build directory which doesn't exist during dependency scanning
    aggregate_target = installer.aggregate_targets.find { |t| t.name == 'Pods-chandrajewellery' }
    if aggregate_target
      xcconfig_paths = [
        "#{installer.sandbox.root}/Target Support Files/#{aggregate_target.name}/#{aggregate_target.name}.debug.xcconfig",
        "#{installer.sandbox.root}/Target Support Files/#{aggregate_target.name}/#{aggregate_target.name}.release.xcconfig"
      ]
      
      xcconfig_paths.each do |xcconfig_path|
        if File.exist?(xcconfig_path)
          xcconfig_content = File.read(xcconfig_path)
          
          # Replace the problematic module map path with the correct one
          # Replace: ${PODS_CONFIGURATION_BUILD_DIR}/react-native-video/react_native_video.modulemap
          # With: ${PODS_ROOT}/Target Support Files/react-native-video/react-native-video.modulemap
          fixed_content = xcconfig_content.gsub(
            /\$\{PODS_CONFIGURATION_BUILD_DIR\}\/react-native-video\/react_native_video\.modulemap/,
            '${PODS_ROOT}/Target Support Files/react-native-video/react-native-video.modulemap'
          )
          
          if fixed_content != xcconfig_content
            File.write(xcconfig_path, fixed_content)
            puts "Fixed react-native-video module map path in #{File.basename(xcconfig_path)}"
          end
        end
      end
    end
  end
end

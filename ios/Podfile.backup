require_relative '../node_modules/react-native/scripts/react_native_pods'
platform :ios, '15.1'
prepare_react_native_project!

target 'chandrajewellery' do
  config = nil
  begin
    config = use_native_modules!
  rescue StandardError => e
    Pod::UI.warn("use_native_modules! failed: #{e}. Falling back without autolinking.")
  end
  config ||= { reactNativePath: '../node_modules/react-native' }

  use_react_native!(
    path: '../node_modules/react-native',
    app_path: "#{Pod::Config.instance.installation_root}/.."
  )

  # Firebase with modular headers
  pod 'GoogleUtilities', :modular_headers => true
  pod 'Firebase/Core', :modular_headers => true
  pod 'Firebase/Messaging', :modular_headers => true

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      mac_catalyst_enabled: false
    )
    
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Fix for all targets
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        
        # Sentry-specific fixes
        if target.name.include?('Sentry') || target.name.include?('sentry')
          puts "Configuring Sentry target: #{target.name}"
          
          # Set C++17 standard
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
          config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
          
          # Disable profiling completely to avoid C++ allocator issues
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          preprocessor_defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
          
          if preprocessor_defs.is_a?(String)
            preprocessor_defs = preprocessor_defs.split(' ')
          end
          
          # Add all profiling disable flags
          profiling_flags = [
            'SENTRY_PROFILING_ENABLED=0',
            'SENTRY_ENABLE_PROFILING=0',
            'SENTRY_PROFILING=0'
          ]
          
          profiling_flags.each do |flag|
            unless preprocessor_defs.include?(flag)
              preprocessor_defs << flag
            end
          end
          
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = preprocessor_defs
          
          # Exclude profiling source files that cause C++ errors
          profiling_files = [
            'SentryThreadMetadataCache.cpp',
            'SentrySamplingProfiler.cpp',
            'SentryThreadHandle.cpp',
            'SentryProfilerState.mm',
            'SentryProfilerSerialization.mm',
            'SentryTraceProfiler.mm',
            'SentryBacktrace',
            'ProfilerState',
            'ThreadMetadata'
          ]
          
          # Remove problematic source files from compilation
          target.source_build_phase.files.each do |file|
            if file.file_ref && file.file_ref.path
              file_path = file.file_ref.path.to_s
              if profiling_files.any? { |pf| file_path.include?(pf) }
                puts "  Removing problematic file: #{file_path}"
                file.remove_from_project
              end
            end
          end
        end
        
        # Firebase/Google fixes for modular issues
        if target.name.include?('Firebase') || target.name.include?('Google')
          config.build_settings['DEFINES_MODULE'] = 'YES'
          config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
        end
      end
    end
    
    # Fix for main app target
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.native_targets.each do |target|
        target.build_configurations.each do |config|
          config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        end
      end
    end
  end
end